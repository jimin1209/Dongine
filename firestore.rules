rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 인증된 사용자만 접근
    function isAuthenticated() {
      return request.auth != null;
    }

    // 가족 구성원인지 확인
    function isFamilyMember(familyId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    // 가족 관리자인지 확인
    function isFamilyAdmin(familyId) {
      return isFamilyMember(familyId) &&
        get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // 역할 값이 유효한지 확인
    function isValidRole() {
      return request.resource.data.role in ['admin', 'member'];
    }

    // 본인 문서인지 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 유효한 초대 코드인지 확인
    function hasValidInvitation(inviteCode, familyId) {
      return inviteCode is string &&
        exists(/databases/$(database)/documents/invitations/$(inviteCode)) &&
        get(/databases/$(database)/documents/invitations/$(inviteCode)).data.familyId == familyId &&
        get(/databases/$(database)/documents/invitations/$(inviteCode)).data.isActive == true &&
        get(/databases/$(database)/documents/invitations/$(inviteCode)).data.expiresAt > request.time;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Families
    match /families/{familyId} {
      function isJoiningFamily() {
        return isAuthenticated() &&
          hasValidInvitation(resource.data.inviteCode, familyId) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberIds']) &&
          request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.resource.data.memberIds.hasAny([request.auth.uid]) &&
          !resource.data.memberIds.hasAny([request.auth.uid]);
      }

      // 본인이 가족을 떠날 때 memberIds에서 자신만 제거
      function isLeavingFamily() {
        return isAuthenticated() &&
          resource.data.memberIds.hasAny([request.auth.uid]) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberIds']) &&
          request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1 &&
          !request.resource.data.memberIds.hasAny([request.auth.uid]) &&
          resource.data.memberIds.hasAll(request.resource.data.memberIds);
      }

      function isCreatingOwnMemberRecord(memberId) {
        return isOwner(memberId) &&
          request.resource.data.role == 'member' &&
          request.resource.data.nickname is string &&
          request.resource.data.joinedAt is timestamp &&
          request.resource.data.locationSharingEnabled is bool &&
          getAfter(/databases/$(database)/documents/families/$(familyId)).data.memberIds.hasAny([memberId]);
      }

      function isCreatingInitialAdminRecord(memberId) {
        return isOwner(memberId) &&
          request.resource.data.role == 'admin' &&
          request.resource.data.nickname is string &&
          request.resource.data.joinedAt is timestamp &&
          request.resource.data.locationSharingEnabled is bool &&
          getAfter(/databases/$(database)/documents/families/$(familyId)).data.createdBy == memberId &&
          getAfter(/databases/$(database)/documents/families/$(familyId)).data.memberIds.size() == 1 &&
          getAfter(/databases/$(database)/documents/families/$(familyId)).data.memberIds.hasAny([memberId]);
      }

      allow get: if isFamilyMember(familyId) ||
        hasValidInvitation(resource.data.inviteCode, familyId);
      allow list: if false;
      allow create: if isAuthenticated();
      allow update: if isFamilyAdmin(familyId) || isJoiningFamily() || isLeavingFamily();
      allow delete: if isFamilyAdmin(familyId);

      // Members
      match /members/{memberId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyAdmin(familyId) ||
          isCreatingOwnMemberRecord(memberId) ||
          isCreatingInitialAdminRecord(memberId);
        allow update: if (isFamilyAdmin(familyId) && isValidRole()) ||
          (isOwner(memberId) && request.resource.data.role == resource.data.role);
        allow delete: if isFamilyAdmin(familyId) || isOwner(memberId);
      }

      // Messages
      match /messages/{messageId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId) &&
          resource.data.senderId == request.auth.uid;
        allow delete: if isFamilyAdmin(familyId) ||
          resource.data.senderId == request.auth.uid;
      }

      // Locations
      match /locations/{userId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId) && isOwner(userId);
      }

      // Files
      match /files/{fileId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyAdmin(familyId) ||
          resource.data.uploadedBy == request.auth.uid;
      }

      // Albums
      match /albums/{albumId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyAdmin(familyId) ||
          resource.data.createdBy == request.auth.uid;

        // Album Photos
        match /photos/{photoId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyAdmin(familyId) ||
            resource.data.uploadedBy == request.auth.uid;
        }
      }

      // Events
      match /events/{eventId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId);
      }

      // TODOs
      match /todos/{todoId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId);
      }

      // Cart
      match /cart/{itemId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId);
      }

      // Expenses
      match /expenses/{expenseId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyAdmin(familyId) ||
          resource.data.createdBy == request.auth.uid;
      }

      // IoT Devices
      match /devices/{deviceId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyAdmin(familyId) ||
          resource.data.addedBy == request.auth.uid;
      }

      // IoT Automations
      match /automations/{automationId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyAdmin(familyId) ||
          resource.data.createdBy == request.auth.uid;
      }
    }

    // Invitations
    match /invitations/{inviteId} {
      allow get: if isAuthenticated();
      allow list: if false;
      allow create: if isAuthenticated() &&
        request.resource.data.familyId is string &&
        request.resource.data.inviteCode == inviteId &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.expiresAt is timestamp &&
        request.resource.data.expiresAt > request.time &&
        (
          isFamilyAdmin(request.resource.data.familyId) ||
          getAfter(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.createdBy == request.auth.uid
        );
      allow update: if isAuthenticated() &&
        resource.data.familyId is string &&
        isFamilyAdmin(resource.data.familyId);
      allow delete: if isAuthenticated() &&
        resource.data.familyId is string &&
        isFamilyAdmin(resource.data.familyId);
    }
  }
}
